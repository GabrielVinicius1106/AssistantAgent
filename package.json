{
  "name": "lynq",
  "version": "1.0.0",
  "description": "An AI Agent App that Integrates with Notion and Google Calendar",
  "license": "ISC",
  "author": "Gabriel Vinícius da Cruz",
  "type": "module",
  "main": "app.js",
  "scripts": {
    "server": "tsx watch ./src/app.ts",
    "test": "vitest run",
    "docker-compose": "docker compose up -d",
    "docker-start": "docker start lynq-postgres && docker start lynq-redis",
    "test:coverage": "vitest run --coverage",
    "migrations": "npx prisma migrate dev",
    "generation": "npx prisma generate",
    "secret": "tsx generateKey.ts"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "^7.7.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.5.2",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.4.0",
    "fastify": "^5.8.4",
    "jsonwebtoken": "^9.0.3",
    "redis": "^5.11.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.4",
    "prisma": "^7.7.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.4"
  }
}
